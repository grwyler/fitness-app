# Local-only Vercel automation config (DO NOT COMMIT real values).
#
# Copy to `.env.vercel.local` and fill in values.
#
# Used by scripts in `scripts/vercel/` and `scripts/github/`.

# Required for Vercel REST API scripts
VERCEL_TOKEN=

# Optional for Vercel REST API calls on a Team (often starts with `team_`)
VERCEL_TEAM_ID=

# Optional for Vercel CLI commands (team slug or ID)
VERCEL_SCOPE=

# Vercel Project IDs (used to avoid interactive `vercel link`)
VERCEL_WEB_PROJECT_ID=
VERCEL_API_PROJECT_ID=

# Optional stable staging domains (used by `vercel:staging:deploy`)
VERCEL_WEB_STAGING_DOMAIN=
VERCEL_API_STAGING_DOMAIN=

