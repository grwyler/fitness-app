{
  "expo": {
    "name": "Fitness App",
    "slug": "fitness-app",
    "scheme": "fitnessapp",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "bundleIdentifier": "com.setwise.fit",
      "supportsTablet": true,
      "buildNumber": "1"
    },
    "android": {
      "package": "com.setwise.fit",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1220"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {}
  }
}
