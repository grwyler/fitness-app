{
  "name": "fitness-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:mobile:web": "npm run build:web --workspace @fitness/mobile",
    "smoke:api:url": "node scripts/smoke-api-url.mjs",
    "smoke:mobile:web": "node scripts/smoke-mobile-web-build.mjs",
    "smoke:url": "node scripts/smoke-url.mjs",
    "typecheck": "tsc -b --pretty false",
    "dev:api": "npm run dev --workspace @fitness/api",
    "dev:mobile": "npm run dev --workspace @fitness/mobile",
    "dev:mobile:web": "npm run dev --workspace @fitness/mobile -- --web"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3"
  }
}
