DATABASE_URL=postgres://postgres:postgres@localhost:5432/fitness_app
USE_PGLITE_DEV=true
PORT=4000
NODE_ENV=development
JWT_SECRET=replace_with_a_random_32_plus_character_secret
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# Deep link or web URL used in password reset emails (token is appended as ?token=...)
PASSWORD_RESET_LINK_BASE_URL=fitnessapp://reset-password

# Email delivery (required in production for password reset)
# EMAIL_PROVIDER=console|resend
EMAIL_PROVIDER=console
# When EMAIL_PROVIDER=resend (production):
# RESEND_API_KEY=...
# EMAIL_FROM="Setwise Fit <no-reply@setwisefit.com>"
# Optional (defaults to JWT_SECRET):
# PASSWORD_RESET_TOKEN_SECRET=replace_with_a_different_random_secret
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:4000/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:8081,https://setwisefit.vercel.app

# Observability / error reporting (Sentry)
# Default behavior:
# - development/test: disabled unless OBSERVABILITY_ENABLED=true and SENTRY_DSN is set
# - production: enabled when SENTRY_DSN is set (can be forced off with OBSERVABILITY_ENABLED=false)
# OBSERVABILITY_ENABLED=true|false
# OBSERVABILITY_ENABLED=true
# SENTRY_DSN=https://...
SENTRY_DSN=
# Optional overrides
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# Mobile / web (Expo) observability (public env vars)
# - development: disabled unless EXPO_PUBLIC_OBSERVABILITY_ENABLED=true and EXPO_PUBLIC_SENTRY_DSN is set
# - production builds: enabled when EXPO_PUBLIC_SENTRY_DSN is set (can be forced off with EXPO_PUBLIC_OBSERVABILITY_ENABLED=false)
# EXPO_PUBLIC_OBSERVABILITY_ENABLED=true
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=
EXPO_PUBLIC_SENTRY_RELEASE=
# Tests use an in-memory PGlite database and do not require a separate test database URL.
# Production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
# JWT_SECRET=generate_a_unique_random_32_plus_character_value
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=...
# EMAIL_FROM="Setwise Fit <no-reply@setwisefit.com>"
# PASSWORD_RESET_LINK_BASE_URL=fitnessapp://reset-password
# EXPO_PUBLIC_API_BASE_URL=https://setwiseapi.vercel.app/api/v1
