# API staging vars for `develop` Preview deployments.
# Copy to `.env.api.staging` (ignored) and fill in values.
#
# Recommended safety model:
# - Default Preview env (no branch): USE_PGLITE_DEV=true, EMAIL_PROVIDER=console
# - develop Preview branch: USE_PGLITE_DEV=false and real staging secrets below

DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=replace-with-a-staging-secret-at-least-32-chars
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_replace_with_staging_key
EMAIL_FROM=Setwise Fit (Staging) <no-reply@example.com>
PASSWORD_RESET_LINK_BASE_URL=https://setwisefit-test.vercel.app/reset-password
CORS_ALLOWED_ORIGINS=https://setwisefit-test.vercel.app,http://localhost:8081
USE_PGLITE_DEV=false
